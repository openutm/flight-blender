# Environment variables for Flight Blender when running against InterUSS uss_qualifier.
# This file is used by testing/interuss/docker-compose.yml.
# DO NOT USE IN PRODUCTION. These are test-only values.

# Django core
SECRET_KEY=interuss-test-secret-key-not-for-production
IS_DEBUG=1

# Auth — point at InterUSS dummy-oauth running on interop_ecosystem_network
# BYPASS_AUTH_TOKEN_VERIFICATION=1 is required because dummy-oauth does not expose
# a /.well-known/jwks.json endpoint that Flight Blender can use to verify tokens.
BYPASS_AUTH_TOKEN_VERIFICATION=1
PASSPORT_URL=http://oauth.authority.localutm:8085
PASSPORT_AUDIENCE=flight-blender.localutm
DSS_AUTH_URL=http://oauth.authority.localutm:8085
DSS_AUTH_TOKEN_ENDPOINT=/token
DSS_AUTH_JWKS_ENDPOINT=http://oauth.authority.localutm:8085/.well-known/jwks.json

# DSS — use the first CockroachDB-backed DSS node started by run_locally.sh
DSS_BASE_URL=http://dss1.uss1.localutm/
DSS_SELF_AUDIENCE=flight-blender.localutm

# Blender self-reference
BLENDER_FQDN=http://flight-blender.localutm:8000

# Database (Postgres container created by this docker-compose)
DATABASE_URL=postgres://testuser:testpass@db-blender-test:5432/testdb
POSTGRES_HOST=db-blender-test
POSTGRES_PORT=5432
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpass
POSTGRES_DB=testdb

# Redis / Celery (Valkey container created by this docker-compose)
REDIS_HOST=redis-blender-test
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_BROKER_URL=redis://redis-blender-test:6379

# Django host/deployment settings
USING_DOCKER_COMPOSE=1
